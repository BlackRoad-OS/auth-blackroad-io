{
  "name": "auth-blackroad-io",
  "version": "1.0.0",
  "description": "BlackRoad Auth Service with Autonomous Agent System",
  "type": "module",
  "main": "src/worker.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "agent:status": "wrangler tail --format pretty",
    "db:migrate": "wrangler d1 migrations apply AGENT_DB",
    "kv:list": "wrangler kv:key list --binding AGENT_STATE"
  },
  "keywords": [
    "cloudflare-workers",
    "autonomous-agents",
    "blackroad",
    "authentication"
  ],
  "author": "BlackRoad OS, Inc.",
  "license": "UNLICENSED",
  "private": true,
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1",
    "wrangler": "^4.76.0"
  },
  "dependencies": {
    "hono": "^4.0.0",
    "zod": "^3.22.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
